<ui:FluentWindow x:Class="AIXray.App.CreateGroupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="ایجاد گروه جدید" Height="320" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="ایجاد گروه جدید" FontSize="18" FontWeight="SemiBold"
                   Margin="0,0,0,16" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

        <StackPanel Grid.Row="1">
            <!-- Name -->
            <TextBlock Text="نام گروه" Margin="0,0,0,4"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <ui:TextBox x:Name="NameBox" PlaceholderText="مثلاً: اشتراک اصلی" Margin="0,0,0,16" />

            <!-- Subscription URL -->
            <TextBlock Text="لینک سابسکریپشن (اختیاری)" Margin="0,0,0,4"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <ui:TextBox x:Name="UrlBox" PlaceholderText="https://example.com/subscription" Margin="0,0,0,16" />

            <!-- Auto Update -->
            <CheckBox x:Name="AutoUpdateCheck" Content="آپدیت خودکار"
                      IsChecked="True" Margin="0,0,0,12" />

            <!-- Update Interval -->
            <TextBlock Text="بازه آپدیت خودکار (دقیقه)" Margin="0,0,0,4"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <ui:TextBox x:Name="IntervalBox" PlaceholderText="60" Width="120"
                         HorizontalAlignment="Left" Margin="0,0,0,16" />
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <ui:Button Content="انصراف" Appearance="Secondary" Click="OnCancel" Margin="0,0,8,0"
                       Padding="20,6" />
            <ui:Button Content="ایجاد" Appearance="Primary" Click="OnOk"
                       Padding="20,6" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
