<ui:FluentWindow x:Class="AIXray.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="AIXray" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <ui:TitleBar Grid.Row="0" Title="AIXray" ShowMaximize="True" ShowMinimize="True">
            <ui:TitleBar.Header>
                <Menu>
                    <MenuItem Header="منو">
                        <MenuItem Header="وارد کردن از فایل" Command="{Binding ImportFromFileCommand}">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="OpenFile24" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="وارد کردن از کلیپ‌بورد" Command="{Binding ImportFromClipboardCommand}">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Copy24" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="ساخت کانفیگ سفارشی" Command="{Binding OpenCustomConfigCommand}">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Add24" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <MenuItem Header="گروه‌ها / سابسکرایب">
                        <MenuItem Header="ایجاد گروه جدید" Command="{Binding CreateGroupCommand}">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Add24" />
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="بروزرسانی با پروکسی" Command="{Binding UpdateAllSubscriptionsCommand}">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="ArrowSync24" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>

                    <MenuItem Header="تنظیمات" Command="{Binding OpenSettingsCommand}">
                        <MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Settings24" />
                        </MenuItem.Icon>
                    </MenuItem>
                </Menu>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Group Tabs -->
            <Border Grid.Column="0" CornerRadius="8" Background="{DynamicResource ControlFillColorDefaultBrush}" Margin="0,0,8,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="گروه‌ها" FontWeight="SemiBold" FontSize="14"
                               Margin="12,12,12,8" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:Button DockPanel.Dock="Bottom" Content="+ ایجاد گروه" Command="{Binding CreateGroupCommand}"
                            HorizontalAlignment="Stretch" Margin="8,8,8,8" Padding="0,6"
                            Appearance="Primary" />
                    <ListBox ItemsSource="{Binding Groups}" SelectedItem="{Binding SelectedGroup}"
                             BorderThickness="0" Background="Transparent" Padding="4">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,2">
                                    <ui:SymbolIcon Symbol="Folder24" Margin="0,0,8,0" FontSize="14"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="12,8" />
                                <Setter Property="Margin" Value="4,1" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{DynamicResource ControlFillColorDefaultBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="{DynamicResource SystemAccentColorLightBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Server List -->
            <Border Grid.Column="1" CornerRadius="8" Background="{DynamicResource ControlFillColorDefaultBrush}">
                <DockPanel>
                    <!-- Toolbar -->
                    <ToolBarTray DockPanel.Dock="Top" Margin="8,8,8,0">
                        <ToolBar Band="0">
                            <Button ToolTip="وارد کردن از فایل" Command="{Binding ImportFromFileCommand}">
                                <ui:SymbolIcon Symbol="OpenFile24" />
                            </Button>
                            <Button ToolTip="وارد کردن از کلیپ‌بورد" Command="{Binding ImportFromClipboardCommand}">
                                <ui:SymbolIcon Symbol="Copy24" />
                            </Button>
                            <Separator />
                            <Button ToolTip="ساخت کانفیگ سفارشی" Command="{Binding OpenCustomConfigCommand}">
                                <ui:SymbolIcon Symbol="Add24" />
                            </Button>
                            <Separator />
                            <Button ToolTip="تست تاخیر همه" Command="{Binding TestAllLatencyCommand}">
                                <ui:SymbolIcon Symbol="Gauge24" />
                            </Button>
                        </ToolBar>
                    </ToolBarTray>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="0" ItemsSource="{Binding Servers}" SelectedItem="{Binding SelectedServer}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Background="Transparent" BorderThickness="0"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              SelectionMode="Single" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="نام" Binding="{Binding Remark}" Width="200" />
                            <DataGridTextColumn Header="پروتکل" Binding="{Binding Protocol}" Width="80" />
                            <DataGridTextColumn Header="آدرس" Binding="{Binding Address}" Width="200" />
                            <DataGridTextColumn Header="پورت" Binding="{Binding Port}" Width="60" />
                            <DataGridTextColumn Header="شبکه" Binding="{Binding Network}" Width="80" />
                            <DataGridTextColumn Header="امنیت" Binding="{Binding Security}" Width="70" />
                            <DataGridTextColumn Header="تاخیر (ms)" Binding="{Binding LatencyMs}" Width="80" />
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="Background" Value="#200078D4" />
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Bottom Bar -->
        <Border Grid.Row="2" Padding="12,8" Background="{DynamicResource ControlFillColorDefaultBrush}"
                CornerRadius="8" Margin="8,0,8,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Auto-connect checkbox -->
                <CheckBox Grid.Column="0" Content="اتصال خودکار"
                          IsChecked="{Binding AutoConnect}"
                          VerticalAlignment="Center" Margin="0,0,16,0"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                <!-- Status text -->
                <TextBlock Grid.Column="1" Text="{Binding StatusText}" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                <!-- Mode selector -->
                <ComboBox Grid.Column="2" Width="160" Margin="0,0,16,0"
                          SelectedValue="{Binding CurrentMode}"
                          VerticalAlignment="Center">
                    <ComboBoxItem Content="پروکسی سیستم" Tag="SystemProxy" />
                    <ComboBoxItem Content="TUN (VPN)" Tag="Tun" />
                    <ComboBoxItem Content="مستقیم" Tag="Direct" />
                </ComboBox>

                <!-- Connect / Disconnect toggle -->
                <ui:Button Grid.Column="3"
                           Appearance="{Binding IsConnected, Converter={StaticResource ConnectButtonConverter}}"
                           Command="{Binding IsConnected, Converter={StaticResource ConnectToggleConverter}, ConverterParameter={x:Reference MainWindow}}"
                           HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="{Binding IsConnected, Converter={StaticResource ConnectIconConverter}}"
                                      Margin="0,0,6,0" />
                        <TextBlock Text="{Binding ConnectionStatusText}" />
                    </StackPanel>
                </ui:Button>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
